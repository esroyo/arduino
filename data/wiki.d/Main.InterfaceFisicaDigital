diff:1391339175:1391277670:=381,528c381%0a%3c 4. [[https://vimeo.com/85610525]]%0a%3c %0a%3c %0a%3c !!! Trabajo Ping Pong Invader%0a%3c !!!Integrantes del grupo: Miriam Berbegal, Sonia Conde, Laura Sanchez, Paloma Valero y Pablo Albero. %0a%3c !!!!Objetivos %0a%3c *Como objetivos principales se nos encomienda realizar un diseño con el que interactuar físicamente. Para ello hemos empleado dos programas, el Processing, para el diseño y el Arduino, para que éste diseño interactue con el espectador mediante un sensor (potenciometro) que permite el movimiento.%0a%3c %0a%3c !!!!Explicación%0a%3c * Para este proyecto interactivo, hemos querido hacer un pequeño guiño al popular juego Pong de los '70, pero usando solo una pala o raqueta, y modificando el diseño incorporando otro guiño aun juego también muy famoso (Space Invaders).%0a%3c *Queríamos crear una interacción divertida, y que a pesar de ser sencilla, pudieras pasarte unos minutos con ella. Un juego era la mejor opción para nosotros.%0a%3c *Al igual que los otros compañeros de clase, hemos tenido que usar la versión 2.1 de 32 bits de Processing, ya que se producia un error a la hora de trabajar con el potenciometro. Para poder hacer uso del potenciometro, enviamos unos valores a la placa Arduino, puerto de la conexión, velocidad de transmision, etc:%0a%3c %0a%3c int potPin=0;  %0a%3c void setup(){ %0a%3c  Serial.begin(19200);%0a%3c  } %0a%3c  %0a%3c void loop(){ %0a%3c  int val=analogRead(potPin);%0a%3c  val=val/4;  %0a%3c  Serial.write(val);  %0a%3c  delay(75);%0a%3c }%0a%3c %0a%3c *Y al igual que añadimos en Arduino, en Processing también añadimos unos comandos para poder lograr esa interacción y junto al resto de codigo, es el siguiente:%0a%3c %0a%3c import processing.serial.*; %0a%3c  %0a%3c String portname = "COM9"; %0a%3c Serial port;%0a%3c %0a%3c //invader %0a%3c float invader_x; %0a%3c float invader_y; %0a%3c float invader_dir = 1; %0a%3c float invader_size = 5; // Radio %0a%3c float dy = 0; // Dirección %0a%3c %0a%3c  %0a%3c // Raqueta %0a%3c int paddle_width = 5; %0a%3c int paddle_height = 30; %0a%3c int paddle_pos; // nueva posición %0a%3c int paddle_ppos; // última posición %0a%3c int dist_wall = 15; %0a%3c %0a%3c PImage invader1,raqueta,Espacio;%0a%3c %0a%3c %0a%3c void setup() %0a%3c { %0a%3c  size(280 , 280); %0a%3c  rectMode(CENTER); %0a%3c  ellipseMode(CENTER); %0a%3c  noStroke(); %0a%3c  smooth(); %0a%3c  %0a%3c  invader_y = height/2; %0a%3c  invader_x = 1;%0a%3c  invader1= loadImage("invader2.png");%0a%3c  raqueta=loadImage("raqueta.png");%0a%3c  Espacio= loadImage("Espacio.jpg");%0a%3c  %0a%3c %0a%3c  port = new Serial(this, portname, 19200); %0a%3c } %0a%3c  %0a%3c void draw() %0a%3c { %0a%3c  background(Espacio); %0a%3c  imageMode(CENTER);%0a%3c  image(invader1,invader_x, invader_y);%0a%3c  %0a%3c  %0a%3c  %0a%3c  invader_x += invader_dir * 2.0; %0a%3c  invader_y += dy; %0a%3c  if(invader_x > width+invader_size) { %0a%3c  invader_x = -width/2 - invader_size; %0a%3c  invader_y = random(0, height); %0a%3c  dy = 0; %0a%3c  %0a%3c  } %0a%3c  %0a%3c  if (port.available() > 0) { %0a%3c  paddle_ppos = paddle_pos; // guarda la ultima posición %0a%3c  paddle_pos = port.read(); // lee y almacena la nueva posición %0a%3c  } %0a%3c  %0a%3c  // Desplazamiento de la raqueta%0a%3c  %0a%3c  float paddle_y = constrain(paddle_pos, paddle_height, height-paddle_height); %0a%3c  %0a%3c  // Reacción pelota con la raqueta%0a%3c  %0a%3c  float py = width-dist_wall-paddle_width-invader_size; %0a%3c  if(invader_x == py %0a%3c  && invader_y > paddle_y - paddle_height - invader_size %0a%3c  && invader_y %3c paddle_y + paddle_height + invader_size) { %0a%3c  invader_dir *= -1; %0a%3c  if(paddle_pos != paddle_ppos) { %0a%3c  dy = (paddle_pos - paddle_ppos)/2.0; %0a%3c  if(dy > 5) { dy = 5; } %0a%3c  if(dy %3c -5) { dy = -5; } %0a%3c  } %0a%3c  } %0a%3c  %0a%3c  // Cambio de la dirección invader%0a%3c  %0a%3c  if(invader_x %3c invader_size && invader_dir == -1) { %0a%3c  invader_dir *= -1; %0a%3c  } %0a%3c  %0a%3c  // Superior o inferior del borde%0a%3c  %0a%3c  if(invader_y > height-invader_size) { %0a%3c  dy = dy * -1; %0a%3c  } %0a%3c  if(invader_y %3c invader_size) { %0a%3c  dy = dy * -1; %0a%3c  } %0a%3c  %0a%3c  // Pelota del invader%0a%3c  %0a%3c  noFill(); %0a%3c  ellipse(invader_x, invader_y, 8, 8); %0a%3c  %0a%3c  // Raqueta%0a%3c  %0a%3c  noFill(); %0a%3c  image(raqueta,260, paddle_y);%0a%3c  rect(width-dist_wall, paddle_y, paddle_width, paddle_height); %0a%3c %0a%3c }%0a%3c %0a%3c %0a%3c !!!! Imagen y video:%0a%3c * Imagen:%0a%3c 1. [[https://www.dropbox.com/s/o0dx2z0vme0th3f/IMG_20140202_112421.jpg?m=]]%0a%3c %0a%3c %0a%3c %0a%3c %0a%3c *Video final de la interaccíon:%0a%3c %0a%3c 1. [[https://www.facebook.com/photo.php?v=737871326232466]]%0a%3c %0a---%0a> 4. [[https://vimeo.com/85610525]]%0a\ No newline at end of file%0a
