diff:1391422564:1391339175:=528,697d527%0a%3c %0a%3c !!! Trabajo en grupo: Jose Antonio Gabaldón, Jose Antonio Sanchez y Pilar Cuadrado.%0a%3c !!!!Objetivos %0a%3c *Creación de una interfaz que cree una metafora con un elemento físico y una programación digital. %0a%3c %0a%3c !!!!Explicación%0a%3c * Pensamos en crear una ironía jugando con la pantalla y el espectador. El concepto es que la palabra tímida que aparece en la pantalla cuando te alejas aparece en gran tamaño y cuando te aproximas a la pantalla disminuye viéndose solo una pequeña mancha.%0a%3c * Hemos utilizado el programa procesing 2.1.1 de 32bits, ya que el de 64bits no funciona con el sensor de proximidad.%0a%3c %0a%3c %0a%3c !!!!Proceso%0a%3c * El primer paso fue crear el código de la palabra en processing:%0a%3c %0a%3c PFont fuente;%0a%3c String message="tímida";%0a%3c float x=0;%0a%3c int sensor;%0a%3c %0a%3c void setup() {%0a%3c   size(950, 700);%0a%3c   fuente=loadFont("Elephant-Italic-48.vlw");%0a%3c %0a%3c   int num=message.length();%0a%3c   //text(message,width/2,height/2);%0a%3c   println(num);%0a%3c }%0a%3c void draw() {%0a%3c   background(100);%0a%3c   fill(255);%0a%3c   sensor=mouseX;%0a%3c   float m= map(sensor,0,width,5,90);%0a%3c   textFont(fuente, m);%0a%3c   textAlign(CENTER, CENTER);%0a%3c   text(message, width/2, height/2);%0a%3c }%0a%3c %0a%3c * En segundo lugar programamos la placa para que recoja los datos del sensor de proximidad:%0a%3c [@%0a%3c /* Ping))) Sensor%0a%3c   %0a%3c    This sketch reads a PING))) ultrasonic rangefinder and returns the%0a%3c    distance to the closest object in range. To do this, it sends a pulse%0a%3c    to the sensor to initiate a reading, then listens for a pulse %0a%3c    to return.  The length of the returning pulse is proportional to %0a%3c    the distance of the object from the sensor.%0a%3c      %0a%3c    The circuit:%0a%3c 	* +V connection of the PING))) attached to +5V%0a%3c 	* GND connection of the PING))) attached to ground%0a%3c 	* SIG connection of the PING))) attached to digital pin 7%0a%3c %0a%3c    http://www.arduino.cc/en/Tutorial/Ping%0a%3c    %0a%3c    created 3 Nov 2008%0a%3c    by David A. Mellis%0a%3c    modified 30 Aug 2011%0a%3c    by Tom Igoe%0a%3c  %0a%3c    This example code is in the public domain.%0a%3c %0a%3c  */%0a%3c %0a%3c // this constant won't change.  It's the pin number%0a%3c // of the sensor's output:%0a%3c const int pingPin = 7;%0a%3c %0a%3c void setup() {%0a%3c   // initialize serial communication:%0a%3c   Serial.begin(9600);%0a%3c }%0a%3c %0a%3c void loop()%0a%3c {%0a%3c   // establish variables for duration of the ping, %0a%3c   // and the distance result in inches and centimeters:%0a%3c   long duration, inches, cm;%0a%3c %0a%3c   // The PING))) is triggered by a HIGH pulse of 2 or more microseconds.%0a%3c   // Give a short LOW pulse beforehand to ensure a clean HIGH pulse:%0a%3c   pinMode(pingPin, OUTPUT);%0a%3c   digitalWrite(pingPin, LOW);%0a%3c   delayMicroseconds(2);%0a%3c   digitalWrite(pingPin, HIGH);%0a%3c   delayMicroseconds(5);%0a%3c   digitalWrite(pingPin, LOW);%0a%3c %0a%3c   // The same pin is used to read the signal from the PING))): a HIGH%0a%3c   // pulse whose duration is the time (in microseconds) from the sending%0a%3c   // of the ping to the reception of its echo off of an object.%0a%3c   pinMode(pingPin, INPUT);%0a%3c   duration = pulseIn(pingPin, HIGH);%0a%3c %0a%3c   // convert the time into a distance%0a%3c   inches = microsecondsToInches(duration);%0a%3c   cm = microsecondsToCentimeters(duration);%0a%3c   %0a%3c   Serial.print(inches);%0a%3c   Serial.print("in, ");%0a%3c   Serial.print(cm);%0a%3c   Serial.print("cm");%0a%3c   Serial.println();%0a%3c   %0a%3c   delay(100);%0a%3c }%0a%3c %0a%3c long microsecondsToInches(long microseconds)%0a%3c {%0a%3c   // According to Parallax's datasheet for the PING))), there are%0a%3c   // 73.746 microseconds per inch (i.e. sound travels at 1130 feet per%0a%3c   // second).  This gives the distance travelled by the ping, outbound%0a%3c   // and return, so we divide by 2 to get the distance of the obstacle.%0a%3c   // See: http://www.parallax.com/dl/docs/prod/acc/28015-PING-v1.3.pdf%0a%3c   return microseconds / 74 / 2;%0a%3c }%0a%3c %0a%3c long microsecondsToCentimeters(long microseconds)%0a%3c {%0a%3c   // The speed of sound is 340 m/s or 29 microseconds per centimeter.%0a%3c   // The ping travels out and back, so to find the distance of the%0a%3c   // object we take half of the distance travelled.%0a%3c   return microseconds / 29 / 2;%0a%3c }%0a%3c * Por último creamos la unión entre procesing y arduino y ajustamos los parámetros del sensor.%0a%3c %0a%3c import processing.serial.*;%0a%3c Serial myPort;%0a%3c int distancia;%0a%3c PFont fuente;%0a%3c String message="Tímida";%0a%3c float x=0;%0a%3c int sensor;%0a%3c int dato;%0a%3c %0a%3c void setup() {%0a%3c   size(950, 700);%0a%3c   fuente=loadFont("Elephant-Italic-48.vlw");%0a%3c   myPort = new Serial(this, Serial. list()[0], 9600);%0a%3c   myPort.bufferUntil('\n');%0a%3c %0a%3c %0a%3c   int num=message.length();%0a%3c   //text(message,width/2,height/2);%0a%3c   println(num);%0a%3c }%0a%3c void draw() {%0a%3c  dato= distancia;%0a%3c   while (myPort.available()>0){%0a%3c     serialEvent(myPort);%0a%3c   }%0a%3c   background(#f79797);%0a%3c   fill(255);%0a%3c   sensor=distancia;%0a%3c   float m= map(dato, 0, width/20, 5, 90);%0a%3c   textFont(fuente, m);%0a%3c   textAlign(CENTER, CENTER);%0a%3c   text(message, width/2, height/2);%0a%3c }%0a%3c %0a%3c void serialEvent(Serial myPort) {%0a%3c   String myString = myPort.readStringUntil('\n');%0a%3c   if (myString != null)%0a%3c   {%0a%3c     int[]nums = int (split(myString, 'i'));%0a%3c     distancia=nums[0];%0a%3c   }%0a%3c }%0a%3c !!!! Imagen y video:%0a%3c * Imagen:%0a%3c %0a%3c *Video final de la interaccíon:%0a
