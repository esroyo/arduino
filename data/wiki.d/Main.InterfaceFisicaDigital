diff:1391276770:1389643560:=28,369c28%0a%3c * [[http://www.dummies.com/how-to/content/how-to-send-multiple-signals-from-the-arduino-to-p.html | Send multiple signals from Arduino to Processing]]%0a%3c %0a%3c %0a%3c %0a%3c !!Objectivos %0a%3c *Creación de una interfaz que cree una metafora con un elemento físico y una programación digital. %0a%3c %0a%3c !! Explicación%0a%3c * Hemos creado una "pecera" que esta conectada a un sensor de proximidad, la metafora es que los peces de un acuario al acercarse mucho alguien huyen, se van, y esto lo hemos querido representar con una pecera en la pantalla, donde los peces estan a su libre albedrio, pero en el momento que el sensor detecta que se acerca algo huyen. El primer pez huye a las 15 pulgadas de cercania, el segundo a las 10 pulgadas de cercania y el tercero a las 5 pulgadas. Se van del centro de la pantalla y cuando se aleja, vuelven a su ritmo habitual. %0a%3c * Hemos utilizado el programa procesing 2.1.1 de 32bits, ya que el de 64bits no funciona con el sensor de proximidad.%0a%3c %0a%3c %0a%3c !!Proceso%0a%3c * El primer paso fue limpiar la placa para prevenir posibles errores.:%0a%3c [@*%0a%3c  * EEPROM Clear%0a%3c  *%0a%3c  * Sets all of the bytes of the EEPROM to 0.%0a%3c  * This example code is in the public domain.%0a%3c %0a%3c  */%0a%3c %0a%3c #include %3cEEPROM.h>%0a%3c %0a%3c void setup()%0a%3c {%0a%3c   // write a 0 to all 512 bytes of the EEPROM%0a%3c   for (int i = 0; i %3c 512; i++)%0a%3c     EEPROM.write(i, 0);%0a%3c     %0a%3c   // turn the LED on when we're done%0a%3c   digitalWrite(13, HIGH);%0a%3c }%0a%3c %0a%3c void loop()%0a%3c {%0a%3c }%0a%3c @] %0a%3c %0a%3c * En segundo lugar programamos la placa para que recoja los datos del sensor de proximidad:%0a%3c [@%0a%3c /* Ping))) Sensor%0a%3c   %0a%3c    This sketch reads a PING))) ultrasonic rangefinder and returns the%0a%3c    distance to the closest object in range. To do this, it sends a pulse%0a%3c    to the sensor to initiate a reading, then listens for a pulse %0a%3c    to return.  The length of the returning pulse is proportional to %0a%3c    the distance of the object from the sensor.%0a%3c      %0a%3c    The circuit:%0a%3c 	* +V connection of the PING))) attached to +5V%0a%3c 	* GND connection of the PING))) attached to ground%0a%3c 	* SIG connection of the PING))) attached to digital pin 7%0a%3c %0a%3c    http://www.arduino.cc/en/Tutorial/Ping%0a%3c    %0a%3c    created 3 Nov 2008%0a%3c    by David A. Mellis%0a%3c    modified 30 Aug 2011%0a%3c    by Tom Igoe%0a%3c  %0a%3c    This example code is in the public domain.%0a%3c %0a%3c  */%0a%3c %0a%3c // this constant won't change.  It's the pin number%0a%3c // of the sensor's output:%0a%3c const int pingPin = 7;%0a%3c %0a%3c void setup() {%0a%3c   // initialize serial communication:%0a%3c   Serial.begin(9600);%0a%3c }%0a%3c %0a%3c void loop()%0a%3c {%0a%3c   // establish variables for duration of the ping, %0a%3c   // and the distance result in inches and centimeters:%0a%3c   long duration, inches, cm;%0a%3c %0a%3c   // The PING))) is triggered by a HIGH pulse of 2 or more microseconds.%0a%3c   // Give a short LOW pulse beforehand to ensure a clean HIGH pulse:%0a%3c   pinMode(pingPin, OUTPUT);%0a%3c   digitalWrite(pingPin, LOW);%0a%3c   delayMicroseconds(2);%0a%3c   digitalWrite(pingPin, HIGH);%0a%3c   delayMicroseconds(5);%0a%3c   digitalWrite(pingPin, LOW);%0a%3c %0a%3c   // The same pin is used to read the signal from the PING))): a HIGH%0a%3c   // pulse whose duration is the time (in microseconds) from the sending%0a%3c   // of the ping to the reception of its echo off of an object.%0a%3c   pinMode(pingPin, INPUT);%0a%3c   duration = pulseIn(pingPin, HIGH);%0a%3c %0a%3c   // convert the time into a distance%0a%3c   inches = microsecondsToInches(duration);%0a%3c   cm = microsecondsToCentimeters(duration);%0a%3c   %0a%3c   Serial.print(inches);%0a%3c   Serial.print("in, ");%0a%3c   Serial.print(cm);%0a%3c   Serial.print("cm");%0a%3c   Serial.println();%0a%3c   %0a%3c   delay(100);%0a%3c }%0a%3c %0a%3c long microsecondsToInches(long microseconds)%0a%3c {%0a%3c   // According to Parallax's datasheet for the PING))), there are%0a%3c   // 73.746 microseconds per inch (i.e. sound travels at 1130 feet per%0a%3c   // second).  This gives the distance travelled by the ping, outbound%0a%3c   // and return, so we divide by 2 to get the distance of the obstacle.%0a%3c   // See: http://www.parallax.com/dl/docs/prod/acc/28015-PING-v1.3.pdf%0a%3c   return microseconds / 74 / 2;%0a%3c }%0a%3c %0a%3c long microsecondsToCentimeters(long microseconds)%0a%3c {%0a%3c   // The speed of sound is 340 m/s or 29 microseconds per centimeter.%0a%3c   // The ping travels out and back, so to find the distance of the%0a%3c   // object we take half of the distance travelled.%0a%3c   return microseconds / 29 / 2;%0a%3c }%0a%3c @]%0a%3c %0a%3c * Por último introducimos el cógigo en el procesing: %0a%3c [@ %0a%3c %0a%3c import processing.serial.*;%0a%3c Serial myPort; // The serial port:%0a%3c /* OpenProcessing Tweak of *@*http://www.openprocessing.org/sketch/28644*@* */%0a%3c /* !do not delete the line above, required for linking your tweak if you upload again */%0a%3c %0a%3c PImage ocean;%0a%3c PImage [] nemo;%0a%3c float x = 0;%0a%3c float x2 = 0;%0a%3c float x3 = 0; %0a%3c float x4 = 0;%0a%3c float x5 = 0;%0a%3c float x6 = 0; %0a%3c float y = 250;%0a%3c float y2 = 150;%0a%3c float y3 = 100; %0a%3c float y4 = 450; %0a%3c float y5 = 50; %0a%3c float y6 = 300; %0a%3c int frame = 0; %0a%3c int frame2 = 2; %0a%3c int frame3 = 3; %0a%3c int frame4 = 1; %0a%3c int frame5 = 4; %0a%3c int frame6 = 5; %0a%3c int W = 100; %0a%3c int H = 75; %0a%3c int A = 3;%0a%3c float B = 3.5; %0a%3c int C = 4; %0a%3c float D = 4.5;%0a%3c int E = 1;%0a%3c float F = 1.5; %0a%3c int counter=0;%0a%3c int cont=0;%0a%3c int distancia=0;%0a%3c int limite=1;%0a%3c  String portname = "/dev/cu.usbserial-3B1";  // find the name of your serial port in your system setup!%0a%3c   int baudrate = 9600;  //  set baudrate here%0a%3c   int value;  // variables used to store value from serial port%0a%3c   String buf=""; // String buffer to store serial values%0a%3c   int value1;  // value1 is the read value%0a%3c %0a%3c %0a%3c %0a%3c void setup() {%0a%3c   frameRate(30); %0a%3c   size(640, 480);%0a%3c   println(Serial.list());%0a%3c   nemo = new PImage[3];%0a%3c   for (int i = 0; i%3c nemo.length; i ++) {%0a%3c     nemo[i] = loadImage("nemo" + (i+1) + ".png");%0a%3c   }%0a%3c   ocean = loadImage("oceanfloor1.jpg");%0a%3c   myPort = new Serial(this, Serial.list()[0], 9600); %0a%3c  // myPort = new Serial(this, portname,baudrate);%0a%3c   myPort.bufferUntil('\n'); %0a%3c  %0a%3c }%0a%3c %0a%3c void draw() {%0a%3c   while(myPort.available() > 0){%0a%3c         //value =myPort.read();%0a%3c         // println(value); %0a%3c         serialEvent(myPort);%0a%3c     }%0a%3c   limite=distancia;%0a%3c   println(limite);%0a%3c   cont++;%0a%3c   if (frame > 2) frame = 0; //fish 1 %0a%3c   if (frame2 >2) frame2 = 0; //fish 2%0a%3c   if (frame3 > 2) frame3 = 0; // fish 3 %0a%3c   if (frame4 >2) frame4 = 0; //fish 4%0a%3c   if (frame5 >2) frame5 = 0; //fish 5%0a%3c   if (frame6 >2) frame6 = 0; //fish 6%0a%3c   image(ocean, 0, 0, 800, 600);%0a%3c   //////////////////////////////////////////////////////////////%0a%3c %0a%3c   pushMatrix();//fish 1%0a%3c   if (distancia%3c=10) {%0a%3c    // A *= -1;%0a%3c     //B *= -1;%0a%3c     translate(0, 0);%0a%3c      //translate(x, y);%0a%3c   }%0a%3c   else {%0a%3c   translate(x+100, y+100);%0a%3c    }%0a%3c   image(nemo[frame], -50, -37.5, W, H);%0a%3c   popMatrix();%0a%3c   %0a%3c     x += A;%0a%3c     y += B; %0a%3c     if (counter%2515==0) {%0a%3c       frame++;%0a%3c     }%0a%3c     if (x>500 || x%3c=0) { %0a%3c       A *= -1;%0a%3c     }%0a%3c     if (y>480 || y%3c=0) {%0a%3c       B *= -1;%0a%3c     }%0a%3c  %0a%3c   /////////////////////////////////////////////////////////%0a%3c   pushMatrix();//fish 2%0a%3c    if (distancia%3c=5) {%0a%3c    // C *= -1;%0a%3c    // D *= -1;%0a%3c     translate(640, 0);%0a%3c      //translate(x, y);%0a%3c   }%0a%3c   else {%0a%3c   translate(x2, y2);%0a%3c    }%0a%3c   image(nemo[frame2], -30, -37, 100, 75);%0a%3c   popMatrix();%0a%3c   x2 += C;%0a%3c   y2 += D;%0a%3c %0a%3c   if (counter%255==0) {%0a%3c     frame2++;%0a%3c   }%0a%3c   if (x2>640 || x2%3c=0) { %0a%3c     C *= -1;%0a%3c   }%0a%3c   if (y2>480 || y2%3c=0) {%0a%3c     D *= -1;%0a%3c   }%0a%3c   ///////////////////////////////////////////////////////%0a%3c   pushMatrix();//fish 3%0a%3c      if (distancia%3c=15) {%0a%3c     //E *= -1;%0a%3c     //F *= -1;%0a%3c     translate(0, 480);%0a%3c      //translate(x, y);%0a%3c   }%0a%3c   else {%0a%3c   translate(x3, y3);%0a%3c    }%0a%3c   image(nemo[frame3], -30, -37, 100, 75);%0a%3c   popMatrix();%0a%3c   x3 += E;%0a%3c   y3 += F; %0a%3c %0a%3c   if (counter%2510==0) {%0a%3c     frame3++;%0a%3c   }%0a%3c %0a%3c   if (x2>640 || x2%3c=0) { %0a%3c     E *= -1;%0a%3c   }%0a%3c   if (y3>480 || y3%3c=0) {%0a%3c     F *= -1;%0a%3c   }%0a%3c  %0a%3c    %0a%3c %0a%3c   counter++;%0a%3c }%0a%3c %0a%3c void keyPressed() {%0a%3c   if (key == '1') {%0a%3c     ocean = loadImage("oceanfloor1.jpg");%0a%3c   }%0a%3c   if (key == '2') {%0a%3c     ocean = loadImage("oceanfloor2.jpg");%0a%3c   }%0a%3c   if (key == '3') {%0a%3c     ocean = loadImage("oceanfloor3.jpg");%0a%3c   }%0a%3c   if (key == 'b') {%0a%3c     H++;%0a%3c     W++;%0a%3c   }%0a%3c }%0a%3c void serialEvent(Serial myPort) {%0a%3c   String myString = myPort.readStringUntil('\n');%0a%3c    if (myString != null)%0a%3c   {%0a%3c      print("Serialized data: ");%0a%3c      println(myString);%0a%3c     int[] nums = int(split(myString, 'i' ));%0a%3c     distancia=nums[0];%0a%3c     println("distancia:",distancia);%0a%3c      // limpio el buffer para que no se sature%0a%3c   myPort.clear();%0a%3c   }%0a%3c  /*if(serial!=10) { %0a%3c            %0a%3c           buf += char(serial);          %0a%3c           } else {%0a%3c           //extract the value from the string 'buf'%0a%3c           buf = buf.substring(1,buf.length());%0a%3c           //cast the value to an integer%0a%3c           value1 = int(buf);%0a%3c           buf="";%0a%3c           println(value1);%0a%3c       }*/%0a%3c  // distancia = int( map(tempDiameter, 0, 1023, 30, 250) );%0a%3c  %0a%3c }%0a%3c %0a%3c @]%0a%3c %0a%3c !! Imagenes y video:%0a%3c * Imagenes:%0a%3c 1. http://imageshack.com/a/img842/3240/z85i.jpg%0a%3c 2. http://imageshack.com/a/img571/9391/m9bt.jpg%0a%3c 3. http://imageshack.com/a/img829/6261/rbr0.jpg%0a%3c 4. http://imageshack.com/a/img40/3033/src.JPG%0a%3c %0a%3c *Videos:%0a---%0a> * [[http://www.dummies.com/how-to/content/how-to-send-multiple-signals-from-the-arduino-to-p.html | Send multiple signals from Arduino to Processing]]%0a\ No newline at end of file%0a
